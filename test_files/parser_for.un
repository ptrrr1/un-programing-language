// Non inclusive
for i in [0..<5] do
	print(i);
end

// Uses alphabetic
for i in ["a"..<"aaaaaaaa"; i] do
	print(i);
end

// Notation is a weird mix of C style and range operator '..'
for i in [10..>0;-3] do
	print(i);
end

for i in [0..<10] do
	if i == 8 then
		break;
	else
		if i == 3 then
			continue;
		else
			print(i);
		end
	end
end
